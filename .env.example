# Configuración para POHAPP API REST
# Copie este archivo a .env y ajuste los valores según su entorno

# Configuración del servidor
PORT=3000
NODE_ENV=development

# Configuración de la base de datos
DB_HOST=localhost
DB_PORT=3306
DB_USER=dbuser
DB_PASSWORD=dbpassword
DB_DATABASE=db-pohapp

# Configuración de seguridad
POHAPP_API_SECRET=your_api_secret_key
POHAPP_ADMIN_KEY=your_admin_key
API_SIGNATURE_TTL=300000 # 5 minutos en milisegundos

# Configuración de CORS (orígenes permitidos)
CORS_WHITELIST=http://localhost:3000,https://pohapp-web.onrender.com

# Configuración de modelos
MODEL_VERSION=v20250504

# Configuración de logging
LOG_LEVEL=debug # (error, warn, info, debug)
